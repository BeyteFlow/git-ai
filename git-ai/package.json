{
  "name": "git-ai",
  "version": "1.0.0",
  "description": "AI-Powered Visual Git CLI for modern developers",
  "type": "module",
  "bin": {
    "ai-git": "./dist/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "echo \"No tests specified\" && exit 1",
    "prepare": "npm run build"
  },
  "keywords": [
    "git",
    "cli",
    "terminal",
    "ai",
    "gemini",
    "automation",
    "github",
    "commit",
    "merge",
    "workflow",
    "developer-tools"
  ],
  "author": "Naheel",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@octokit/rest": "^20.1.1",
    "archy": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "react": "^18.3.1",
    "simple-git": "^3.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archy": "^0.0.34",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.3",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0"
  }
}